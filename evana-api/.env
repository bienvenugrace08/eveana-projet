# Serveur
PORT=3000

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=evana_db

# TypeORM ne doit JAMAIS auto-synchroniser en production : on importe schema.sql
DB_SYNCHRONIZE=false

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=1d

# CORS (URL du frontend Vite)
FRONTEND_URL=http://localhost:5174
